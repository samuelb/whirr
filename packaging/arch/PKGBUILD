# Maintainer: Whirr contributors
# System-tray player for internet radio (MP3) streams.
#
# The committed copy of this file is a generic VCS build: latest git state,
# version derived from `git describe`, checksum SKIP. The release pipeline
# (scripts/stage-arch-release.sh) renders a pinned copy -- fixed pkgver,
# release-tarball source, real checksum -- and attaches it to each GitHub
# release.
pkgname=whirr
pkgver=0.5.2
pkgrel=1
pkgdesc="System-tray player for internet radio (MP3) streams"
arch=('x86_64' 'aarch64')
url="https://github.com/samuelb/whirr"
license=('MIT')
# ring's C sources can't be built with makepkg's default LTO (-flto=auto
# produces GCC bitcode objects that rustc's linker can't read).
options=(!lto)
depends=('gtk3' 'libayatana-appindicator' 'alsa-lib')
makedepends=('rust' 'cargo' 'git')
source=("$pkgname::git+$url.git")
sha256sums=('SKIP')

pkgver() {
    cd "$pkgname"
    git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
    cd "$pkgname"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release --all-features
}

check() {
    cd "$pkgname"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --frozen --release
}

package() {
    cd "$pkgname"
    install -Dm0755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dm0644 "assets/icons/whirr.png" \
        "$pkgdir/usr/share/icons/hicolor/256x256/apps/io.github.samuelb.whirr.png"
    install -Dm0644 "assets/io.github.samuelb.whirr.desktop" \
        "$pkgdir/usr/share/applications/io.github.samuelb.whirr.desktop"
    install -Dm0644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm0644 "LICENSE-MIT" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
